{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Cloudflare Worker (wrangler dev)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["wrangler", "dev"],
      "port": 8787
    },
    {
      "name": "Frontend (static server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "frontend", "--listen", "3000"],
      "port": 3000
    }
  ]
}
